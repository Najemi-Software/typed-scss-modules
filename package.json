{
    "name": "@najemi-software/typed-scss-modules",
    "version": "0.0.0",
    "private": false,
    "description": "TypeScript type definition generator for SCSS CSS Modules",
    "keywords": [
        "cli",
        "css modules",
        "scss",
        "scss modules",
        "type generator",
        "typescript"
    ],
    "homepage": "https://github.com/Najemi-Software/typed-scss-modules#readme",
    "license": "MIT",
    "author": "Martin Najemi <martin@najemi.cz>",
    "contributors": [
        {
            "name": "am0wa",
            "email": "am0wa.it@gmail.com"
        },
        {
            "name": "Spencer Miskoviak",
            "email": "smiskoviak@gmail.com"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Najemi-Software/typed-scss-modules.git"
    },
    "bin": {
        "typed-scss-modules": "./esm/cli.js"
    },
    "files": [
        "esm"
    ],
    "type": "module",
    "main": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
        ".": {
            "types": "./esm/index.d.ts",
            "import": "./esm/index.js",
            "require": "./esm/index.js",
            "default": "./esm/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "api-extractor": "mkdir -p api && [ -z \"${CI}\" ] && (api-extractor run -l) || (api-extractor run)",
        "build": "pnpm run clean && npm-run-all -p build-check build-ts && pnpm run api-extractor",
        "build-check": "tsgo",
        "build-ts": "tsgo -p tsconfig.build.json && chmod +x esm/cli.js",
        "clean": "rm -rf ./esm",
        "format": "oxfmt --check",
        "format-fix": "oxfmt",
        "lint": "oxlint . && eslint .",
        "lint-fix": "oxlint . --fix && eslint . --fix",
        "prepare": "npm run build && husky",
        "test": "vitest",
        "test-once": "vitest run --silent",
        "typed-scss-modules": "node ./esm/cli.js",
        "validate": "pnpm run lint && pnpm run format"
    },
    "dependencies": {
        "chalk": "4.1.2",
        "change-case": "^4.1.2",
        "chokidar": "^3.6.0",
        "glob": "^13.0.0",
        "joycon": "^3.1.1",
        "postcss": "^8.4.49",
        "postcss-modules": "^6.0.1",
        "reserved-words": "^0.1.2",
        "rolldown": "^1.1.5",
        "rolldown-require": "^2.0.20",
        "slash": "^3.0.0",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@eslint/js": "9.28.0",
        "@gooddata/eslint-config": "^11.46.0",
        "@gooddata/oxlint-config": "^11.46.0",
        "@microsoft/api-extractor": "^7.55.2",
        "@types/node": "^22.19.3",
        "@types/reserved-words": "^0.1.0",
        "@types/yargs": "^17.0.35",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@vitest/eslint-plugin": "1.6.6",
        "eslint": "^9.39.2",
        "eslint-plugin-headers": "1.3.3",
        "eslint-plugin-import-esm": "1.2.1",
        "eslint-plugin-jsdoc": "62.1.0",
        "eslint-plugin-no-barrel-files": "1.2.2",
        "eslint-plugin-no-only-tests": "3.3.0",
        "eslint-plugin-sonarjs": "3.0.6",
        "globals": "17.2.0",
        "husky": "^9.1.7",
        "jiti": "2.6.1",
        "lint-staged": "^16.2.7",
        "npm-run-all": "^4.1.5",
        "oxfmt": "^0.52.0",
        "oxlint": "1.51.0",
        "oxlint-tsgolint": "0.15.0",
        "sass": "^1.97.1",
        "sass-embedded": "^1.97.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "vitest": "^4.1.10"
    },
    "peerDependencies": {
        "sass": "^1.97.1",
        "sass-embedded": "^1.97.1"
    },
    "peerDependenciesMeta": {
        "sass": {
            "optional": true
        },
        "sass-embedded": {
            "optional": true
        }
    },
    "lint-staged": {
        "*.{js,mjs,cjs,ts,tsx,jsx}": [
            "sh -c 'eslint --fix \"$@\" || true' --",
            "sh -c 'oxfmt \"$@\" || true' --"
        ],
        "*.json": [
            "sh -c 'oxfmt \"$@\" || true' --"
        ]
    },
    "engines": {
        "node": ">=22.19",
        "pnpm": ">=11"
    },
    "packageManager": "pnpm@11.12.0"
}
